# === CiNect Frontend Environment Variables ===

# API Base URL
# Leave UNSET to auto-detect which backend is running (NestJS:3001 or Spring:8081).
# Set explicitly only if you want to force a specific backend:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1   # NestJS
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1   # Spring Boot

# App Config
NEXT_PUBLIC_APP_NAME=CinemaConnect
NEXT_PUBLIC_ENV=local
# Optional: canonical site URL (used by sitemap/SEO in production)
# NEXT_PUBLIC_SITE_URL=https://cinemaconnect.com

# Optional: Google Maps Geocoding (browser). Restrict the key by HTTP referrer in Google Cloud.
# Improves matching city from GPS; without it, the app uses distance to city centers inside Vietnam.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: travel mode used for "Directions from my location" links.
# Accepted values: driving, walking, bicycling, transit
# NEXT_PUBLIC_MAPS_TRAVEL_MODE=driving
